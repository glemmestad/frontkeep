# Frontkeep local environment. Copy to `.env` (gitignored) and fill in.
# Loaded at startup by the `frontkeep` binary; real env vars override these.
# Only set what you need — every var is optional and degrades gracefully.

# --- Inference modules (standard, enableable) -------------------------------
# Inference backends are service modules in the catalog (services/<id>/service.yaml).
# A module activates when its credentials are present here. Projects get a Frontkeep
# token, never these master keys; spend is attributed per token.
#
# Built-in lightweight floor (zero extra deps), not OpenAI-tied:
OPENAI_MASTER_KEY=            # enables the `openai` module (gpt-5.1, …)
ANTHROPIC_MASTER_KEY=         # enables the `anthropic` module (Claude)
#
# Standard upgrade module — point at a LiteLLM proxy for 100+ providers/fallbacks.
# Enabling = setting LITELLM_BASE_URL (deploy LiteLLM alongside Frontkeep, e.g. Helm).
# LITELLM_BASE_URL=http://localhost:4000
# LITELLM_MASTER_KEY=

# --- Core ------------------------------------------------------------------
# FRONTKEEP_DATABASE_URL=sqlite://frontkeep.db   # or postgres://user:pass@host/db
# FRONTKEEP_BIND=0.0.0.0:8080
# FRONTKEEP_SECRET_KEY=                         # 64 hex chars (32 bytes) for the builtin secret store
# FRONTKEEP_GUARDRAIL_MODE=enforce              # or: monitor
# FRONTKEEP_ADMIN_USER=admin
# FRONTKEEP_ADMIN_PASSWORD=                     # seeds a local admin on boot

# --- Catalog source ingestion ----------------------------------------------
# FRONTKEEP_GIT_TOKEN=                          # GitHub/GitLab token for reconciling manifest repos

# --- Provisioning backends / cost sources ----------------------------------
# AWS connector + Cost Explorer source are configured per-account in frontkeep.yaml
# (provisioning.aws); these are the ambient creds the AWS CLI / SDK reads:
# AWS_PROFILE=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Auth0 (identity, when wired) ------------------------------------------
# AUTH0_DOMAIN=
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
