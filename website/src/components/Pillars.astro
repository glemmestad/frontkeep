---
import { pillars } from '../data/site';

const icons: Record<string, string> = {
  catalog: '<path d="M4 6h16M4 12h16M4 18h10"/><circle cx="19" cy="18" r="2"/>',
  gate: '<path d="M5 21V5a2 2 0 0 1 2-2h6l6 6v12"/><path d="M13 3v6h6"/><path d="M9 14l2 2 4-4"/>',
  gateway: '<path d="M12 3v4M12 17v4M3 12h4M17 12h4"/><circle cx="12" cy="12" r="4"/>',
  policy: '<path d="M12 3l8 3v6c0 4-3.4 7.4-8 9-4.6-1.6-8-5-8-9V6z"/><path d="M9 12l2 2 4-4"/>',
  cost: '<path d="M3 20V4M3 20h18"/><path d="M7 16l4-5 3 3 5-7"/>',
  knowledge: '<path d="M4 5a2 2 0 0 1 2-2h6v18H6a2 2 0 0 1-2-2z"/><path d="M20 5a2 2 0 0 0-2-2h-6v18h6a2 2 0 0 0 2-2z"/>',
};
---
<section class="platform section-pad" id="platform">
  <div class="container">
    <div class="head">
      <span class="eyebrow" data-reveal>The platform</span>
      <h2 data-reveal>Six load-bearing parts. One static binary.</h2>
      <p class="lede" data-reveal>
        The governance spine (catalog, gate, gateway, policy, cost and knowledge) exposed over
        CLI, MCP, REST + GraphQL and an embedded UI. SQLite by default, Postgres when you scale.
      </p>
    </div>

    <div class="grid pillars">
      {pillars.map((p, i) => (
        <article class="pillar panel" data-reveal style={`transition-delay:${(i % 3) * 80}ms`}>
          <span class="ic" set:html={`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${icons[p.icon]}</svg>`} />
          <h3>{p.title}</h3>
          <p>{p.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .head { max-width: 680px; display: flex; flex-direction: column; gap: 16px; margin-bottom: 48px; }
  .head h2 { font-size: clamp(30px, 4.4vw, 52px); }

  .pillars { grid-template-columns: repeat(3, 1fr); }
  .pillar {
    padding: 26px 24px 28px;
    transition: border-color 0.2s, transform 0.2s, opacity 0.7s var(--ease);
  }
  .pillar:hover { border-color: var(--line-2); transform: translateY(-3px); }
  .pillar.in:hover { transform: translateY(-3px); }
  .ic {
    width: 42px; height: 42px; border-radius: 11px;
    display: grid; place-items: center; color: var(--teal);
    border: 1px solid rgba(45, 212, 191, 0.22); background: rgba(45, 212, 191, 0.05);
    margin-bottom: 18px;
  }
  .ic :global(svg) { width: 21px; height: 21px; }
  .pillar h3 { font-size: 20px; margin-bottom: 9px; }
  .pillar p { margin: 0; color: var(--muted); font-size: 14.5px; line-height: 1.58; }

  @media (max-width: 920px) { .pillars { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .pillars { grid-template-columns: 1fr; } }
</style>
