---
import { pillars } from '../data/site';
---
<section class="section platform" id="platform">
  <div class="container">
    <span class="eyebrow">The platform</span>
    <h2>Six load-bearing parts. One static binary.</h2>
    <p class="lede">
      The governance spine — catalog, gate, gateway, policy, cost and knowledge — exposed over
      CLI, MCP, REST + GraphQL and an embedded UI. SQLite by default, Postgres when you scale.
    </p>

    <div class="pillars">
      {pillars.map((p) => (
        <article class="pillar">
          <h3>{p.title}</h3>
          <p>{p.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .platform h2 { font-size: 36px; line-height: 1.15; margin: 16px 0 16px; max-width: 24ch; }

  .pillars {
    margin-top: 48px;
    display: grid; grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .pillar {
    padding: 26px 26px 28px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .pillar:nth-child(3n) { border-right: 0; }
  .pillar:nth-last-child(-n+3) { border-bottom: 0; }
  .pillar h3 { font-size: 17px; margin: 0 0 8px; font-weight: 600; }
  .pillar p { margin: 0; color: var(--fg-muted); font-size: 14.5px; line-height: 1.55; }

  @media (max-width: 920px) {
    .pillars { grid-template-columns: 1fr 1fr; }
    .pillar { border-right: 1px solid var(--line); }
    .pillar:nth-child(3n) { border-right: 1px solid var(--line); }
    .pillar:nth-child(2n) { border-right: 0; }
    .pillar:nth-last-child(-n+3) { border-bottom: 1px solid var(--line); }
    .pillar:nth-last-child(-n+2) { border-bottom: 0; }
  }
  @media (max-width: 560px) {
    .platform h2 { font-size: 28px; }
    .pillars { grid-template-columns: 1fr; }
    .pillar, .pillar:nth-child(3n), .pillar:nth-child(2n) { border-right: 0; }
    .pillar { border-bottom: 1px solid var(--line); }
    .pillar:last-child { border-bottom: 0; }
  }
</style>
