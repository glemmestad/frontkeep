---
const without = [
  ['standards',      'Built to no shared standard — quality is whatever the model defaulted to.'],
  ['classification', 'Data classification unknown; secrets and PII leak through prompts.'],
  ['attribution',    'Spend lands on a mystery bill, attributable to no one.'],
  ['audit',          'No audit trail, no owner, no kill switch.'],
  ['discovery',      'Can’t be handed to a colleague without becoming their liability.'],
  ['policy',         'Quietly outside IT policy — until it isn’t.'],
];
const withFK = [
  ['standards',      'Reads your standards before it writes a line of code.'],
  ['classification', 'Classified and policy-checked on every model call.'],
  ['attribution',    'Every dollar attributed to a project, owner and group.'],
  ['audit',          'Full audit trail and a kill switch across the fleet.'],
  ['discovery',      'Discoverable in the catalog; safe to share and reuse.'],
  ['policy',         'Inside IT policy by construction, not by memo.'],
];
---
<section class="section why" id="why">
  <div class="container">
    <span class="eyebrow">Where agents do real work</span>
    <h2>Your teams’ agents are already shipping software. Where do they do it?</h2>
    <p class="lede">
      People are pointing agents at real problems and shipping software that fills a void —
      faster than any roadmap can. The question isn’t whether to allow it. It’s where the
      work happens. Frontkeep is that place: the front door agents work through, with your
      standards, budgets, audit trail and kill switch built in.
    </p>

    <div class="contrast panel">
      <div class="col">
        <div class="col-head">
          <span class="tag"><span class="dot"></span>Agents without a workplace</span>
        </div>
        <ul>
          {without.map(([k, v]) => (
            <li><span class="key">{k}</span><span class="val">{v}</span></li>
          ))}
        </ul>
      </div>
      <div class="col right">
        <div class="col-head">
          <span class="tag brand"><span class="dot"></span>Agents on Frontkeep</span>
        </div>
        <ul>
          {withFK.map(([k, v]) => (
            <li><span class="key">{k}</span><span class="val">{v}</span></li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .why h2 {
    font-size: 36px; line-height: 1.15;
    margin: 16px 0 16px;
    max-width: 24ch;
  }
  .contrast {
    margin-top: 48px;
    display: grid; grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }
  .col { padding: 28px 28px 24px; }
  .col + .col { border-left: 1px solid var(--line); }
  .col-head {
    display: flex; align-items: center; gap: 10px;
    padding-bottom: 18px;
    margin-bottom: 4px;
    border-bottom: 1px solid var(--line);
  }
  .col ul { list-style: none; margin: 0; padding: 0; }
  .col li {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 16px;
    padding: 14px 0;
    font-size: 14.5px;
    line-height: 1.5;
    border-bottom: 1px solid var(--line);
  }
  .col li:last-child { border-bottom: 0; }
  .col .key {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--fg-faint);
    padding-top: 1px;
  }
  .col .val { color: var(--fg-muted); }
  .col.right .val { color: var(--fg); }

  @media (max-width: 760px) {
    .why h2 { font-size: 28px; }
    .contrast { grid-template-columns: 1fr; }
    .col + .col { border-left: 0; border-top: 1px solid var(--line); }
    .col li { grid-template-columns: 90px 1fr; gap: 12px; }
  }
</style>
