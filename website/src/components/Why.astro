---
const shadow = [
  'Built to no shared standard, quality is whatever the model defaulted to',
  'Data classification unknown; secrets and PII leak through prompts',
  'Spend lands on a mystery bill, attributable to no one',
  'No audit trail, no owner, no kill switch',
  'Can’t be handed to a colleague without becoming their liability',
  'Quietly outside IT policy, until it isn’t',
];
const governed = [
  'Reads your standards before it writes a line',
  'Classified and policy-checked on every model call',
  'Every dollar attributed to a project, owner and group',
  'Full audit trail and a kill switch across the fleet',
  'Discoverable in the catalog, safe to share and reuse',
  'Inside IT policy by construction, not by memo',
];
const check = '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8.5l3.2 3.2L13 5"/></svg>';
const cross = '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4l8 8M12 4l-8 8"/></svg>';
---
<section class="why section-pad" id="why">
  <div class="container">
    <span class="eyebrow" data-reveal>Where agents do real work</span>

    <div class="msg" data-reveal>
      <div class="msg-av">SK</div>
      <div class="msg-body">
        <div class="msg-meta"><b>Sam K.</b><span class="role">Marketing Ops</span><span class="time">11:42</span></div>
        <div class="msg-text">Hey, I just built this piece of software we need! 🙌 It pulls from the warehouse and writes our weekly deck automatically. Isn’t this cool? Want me to share it with everyone??</div>
        <div class="msg-react"><span class="re">🎉 14</span><span class="re">🚀 6</span></div>
      </div>
    </div>

    <div class="why-grid">
      <h2 data-reveal>
        Your teams’ agents are already shipping software.
        <span class="grad-text">Where do they do it?</span>
      </h2>
      <p class="lede" data-reveal>
        In every department, people are pointing agents at real problems and shipping software
        that fills a void, faster than any roadmap can. The question isn’t whether to allow it;
        it’s where the work happens. Frontkeep is that place — the front door agents work through,
        with your standards, budgets, audit trail and kill switch <em>built in</em>. Agents ship
        at AI speed; nothing leaves the building unattributed.
      </p>
    </div>

    <div class="contrast">
      <article class="col shadow-col" data-reveal>
        <div class="col-head">
          <span class="col-tag">Agents without a workplace</span>
        </div>
        <ul>
          {shadow.map((s) => (
            <li><span class="mk x" set:html={cross} />{s}</li>
          ))}
        </ul>
      </article>

      <div class="arrow" aria-hidden="true">
        <span class="arrow-line"></span>
        <span class="arrow-head">→</span>
      </div>

      <article class="col gov-col" data-reveal style="transition-delay:90ms">
        <div class="col-head">
          <span class="col-tag gov">Agents on Frontkeep</span>
        </div>
        <ul>
          {governed.map((g) => (
            <li><span class="mk c" set:html={check} />{g}</li>
          ))}
        </ul>
      </article>
    </div>
  </div>
</section>

<style>
  .msg {
    display: flex; gap: 13px; align-items: flex-start;
    background: var(--panel); border: 1px solid var(--line); border-radius: var(--radius);
    padding: 16px 18px; max-width: 560px; margin: 22px 0 6px;
    box-shadow: 0 1px 2px rgba(21, 24, 29, 0.04);
  }
  .msg-av {
    flex: none; width: 38px; height: 38px; border-radius: 9px;
    display: grid; place-items: center; font-family: var(--mono); font-size: 13px; font-weight: 600;
    color: var(--teal-2); background: rgba(13, 148, 136, 0.1); border: 1px solid rgba(13, 148, 136, 0.2);
  }
  .msg-meta { display: flex; align-items: baseline; gap: 8px; margin-bottom: 4px; }
  .msg-meta b { font-size: 14px; }
  .msg-meta .role { font-size: 12px; color: var(--muted); }
  .msg-meta .time { font-size: 11px; color: var(--muted-2); font-family: var(--mono); margin-left: auto; }
  .msg-text { font-size: 14.5px; color: var(--fg-dim); line-height: 1.5; }
  .msg-react { display: flex; gap: 7px; margin-top: 10px; }
  .msg-react .re {
    font-size: 12px; color: var(--fg-dim); background: var(--bg-2);
    border: 1px solid var(--line); border-radius: 999px; padding: 2px 9px;
  }

  .why-grid {
    display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 40px; align-items: end;
    margin-top: 30px;
  }
  .why-grid h2 { font-size: clamp(28px, 3.8vw, 46px); }
  .why-grid em { font-style: normal; color: var(--teal-2); }

  .contrast {
    display: grid; grid-template-columns: 1fr auto 1fr; gap: 18px; align-items: stretch;
    margin-top: 52px;
  }
  .col { background: var(--panel); border: 1px solid var(--line); border-radius: var(--radius); padding: 24px 24px 26px; }
  .shadow-col { background: var(--panel-2); }
  .gov-col { border-color: rgba(13, 148, 136, 0.28); box-shadow: 0 1px 0 rgba(13,148,136,.04); position: relative; }
  .gov-col::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: var(--bifrost); opacity: 0.75; border-radius: var(--radius) var(--radius) 0 0;
  }

  .col-head { margin-bottom: 18px; }
  .col-tag {
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--muted); border: 1px solid var(--line-2); border-radius: 999px; padding: 5px 12px;
    display: inline-block;
  }
  .col-tag.gov { color: var(--teal-2); border-color: rgba(13, 148, 136, 0.35); background: rgba(13, 148, 136, 0.06); }

  .col ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 13px; }
  .col li { display: flex; gap: 11px; font-size: 14.5px; line-height: 1.5; color: var(--fg-dim); }
  .mk { flex: none; width: 18px; height: 18px; border-radius: 6px; display: grid; place-items: center; margin-top: 1px; }
  .mk :global(svg) { width: 11px; height: 11px; }
  .mk.x { color: var(--muted-2); background: var(--bg-2); }
  .mk.c { color: var(--teal); background: rgba(13, 148, 136, 0.1); }
  .shadow-col li { color: var(--muted); }

  .arrow { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; color: var(--muted-2); }
  .arrow-line { width: 1px; flex: 1; background: linear-gradient(var(--line-2), transparent); }
  .arrow-head { font-size: 20px; color: var(--teal); }

  @media (max-width: 880px) {
    .why-grid { grid-template-columns: 1fr; gap: 18px; }
    .contrast { grid-template-columns: 1fr; }
    .arrow { flex-direction: row; padding: 4px 0; }
    .arrow-line { width: 40px; height: 1px; flex: none; background: var(--line-2); }
    .arrow-head { transform: rotate(90deg); }
  }
</style>
