---
import Logo from './Logo.astro';
import { nav, site } from '../data/site';
---
<header class="nav">
  <div class="container nav-inner">
    <Logo />
    <nav class="links" aria-label="Primary">
      {nav.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
    <div class="actions">
      <a class="ghost-link" href={site.github}>GitHub</a>
      <a class="btn btn-primary btn-sm" href={site.docs}>Get started</a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--line);
    background: var(--bg);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-top: 14px;
    padding-bottom: 14px;
  }
  .links { display: flex; gap: 22px; }
  .links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--fg-muted);
    transition: color 0.1s;
  }
  .links a:hover { color: var(--fg); text-decoration: none; }
  .actions { display: flex; align-items: center; gap: 16px; }
  .ghost-link { font-size: 14px; color: var(--fg-muted); }
  .ghost-link:hover { color: var(--fg); text-decoration: none; }

  @media (max-width: 880px) { .links { display: none; } }
  @media (max-width: 480px) { .ghost-link { display: none; } }
</style>
