---
import { openCore } from '../data/site';
const { oss, enterprise } = openCore;

const check = '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8.5l3.2 3.2L13 5"/></svg>';
---
<section class="oc section-pad" id="open-core">
  <div class="container">
    <div class="head">
      <span class="eyebrow" data-reveal>Open core</span>
      <h2 data-reveal>The whole spine is open source.</h2>
      <p class="lede" data-reveal>
        The governance core is Apache&nbsp;2.0, free to self-host, forever. Enterprise features sit
        behind clean trait seams in the same binary, so there’s no fork and no second product to run.
      </p>
    </div>

    <div class="plans">
      <article class="plan panel" data-reveal>
        <div class="plan-head">
          <div>
            <span class="plan-label">{oss.label}</span>
            <span class="plan-price">{oss.price}</span>
          </div>
          <span class="tag teal">Free forever</span>
        </div>
        <p class="plan-blurb">{oss.blurb}</p>
        <ul class="feat">
          {oss.features.map((f) => (
            <li><span class="ck on" set:html={check} />{f}</li>
          ))}
        </ul>
        <a class="btn btn-primary full" href={oss.cta.href}>{oss.cta.label}</a>
      </article>

      <article class="plan panel ent" data-reveal style="transition-delay:90ms">
        <div class="plan-head">
          <div>
            <span class="plan-label">{enterprise.label}</span>
            <span class="plan-price">{enterprise.price}</span>
          </div>
          <span class="tag violet">Coming soon</span>
        </div>
        <p class="plan-blurb">{enterprise.blurb}</p>
        <ul class="feat">
          {enterprise.features.map((f) => (
            <li><span class="ck ent-ck" set:html={check} />{f}</li>
          ))}
        </ul>
        <a class="btn btn-ghost full" href={enterprise.cta.href}>{enterprise.cta.label}</a>
        <p class="ent-note">{enterprise.note}</p>
      </article>
    </div>
  </div>
</section>

<style>
  .head { max-width: 640px; display: flex; flex-direction: column; gap: 16px; margin-bottom: 48px; }
  .head h2 { font-size: clamp(30px, 4.4vw, 52px); }

  .plans { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; align-items: start; }
  .plan { padding: 30px 28px; display: flex; flex-direction: column; gap: 18px; }
  .plan.ent { position: relative; }
  .plan.ent { border-color: rgba(124, 58, 237, 0.28); }
  .plan.ent::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--violet), var(--blue)); opacity: 0.6;
    border-radius: var(--radius) var(--radius) 0 0; pointer-events: none;
  }
  .plan-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
  .plan-label { display: block; font-family: var(--display); font-weight: 700; font-size: 22px; }
  .plan-price { display: block; font-family: var(--mono); font-size: 13px; color: var(--muted); margin-top: 4px; }
  .plan-blurb { margin: 0; color: var(--fg-dim); font-size: 15px; line-height: 1.55; }

  .feat { list-style: none; margin: 4px 0; padding: 0; display: flex; flex-direction: column; gap: 12px; flex: 1; }
  .feat li { display: flex; gap: 11px; font-size: 14.5px; color: var(--fg-dim); line-height: 1.5; }
  .ck { flex: none; width: 18px; height: 18px; border-radius: 6px; display: grid; place-items: center; margin-top: 1px; }
  .ck :global(svg) { width: 11px; height: 11px; }
  .ck.on { color: var(--teal); background: rgba(45, 212, 191, 0.1); }
  .ck.ent-ck { color: var(--violet); background: rgba(167, 139, 250, 0.1); }

  .btn.full { width: 100%; justify-content: center; margin-top: 6px; }
  .ent-note { margin: 2px 0 0; font-size: 12.5px; color: var(--muted); text-align: center; line-height: 1.5; }

  @media (max-width: 760px) { .plans { grid-template-columns: 1fr; } }
</style>
