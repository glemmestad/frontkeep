---
import { openCore } from '../data/site';
const { oss, enterprise } = openCore;
---
<section class="section oc" id="open-core">
  <div class="container">
    <span class="eyebrow">Open core</span>
    <h2>The whole spine is open source.</h2>
    <p class="lede">
      The governance core is Apache&nbsp;2.0, free to self-host, forever. Enterprise features sit
      behind clean trait seams in the same binary, so there’s no fork and no second product to run.
    </p>

    <div class="plans">
      <article class="plan">
        <div class="plan-head">
          <span class="plan-label">{oss.label}</span>
          <span class="plan-price">{oss.price}</span>
          <span class="tag brand"><span class="dot"></span>Free forever</span>
        </div>
        <p class="plan-blurb">{oss.blurb}</p>
        <ul class="feat">
          {oss.features.map((f) => <li>{f}</li>)}
        </ul>
        <a class="btn btn-primary btn-full" href={oss.cta.href}>{oss.cta.label}</a>
      </article>

      <article class="plan">
        <div class="plan-head">
          <span class="plan-label">{enterprise.label}</span>
          <span class="plan-price">{enterprise.price}</span>
          <span class="tag"><span class="dot"></span>Coming soon</span>
        </div>
        <p class="plan-blurb">{enterprise.blurb}</p>
        <ul class="feat">
          {enterprise.features.map((f) => <li>{f}</li>)}
        </ul>
        <a class="btn btn-ghost btn-full" href={enterprise.cta.href}>{enterprise.cta.label}</a>
        <p class="ent-note">{enterprise.note}</p>
      </article>
    </div>
  </div>
</section>

<style>
  .oc h2 { font-size: 36px; line-height: 1.15; margin: 16px 0 16px; max-width: 24ch; }

  .plans {
    margin-top: 48px;
    display: grid; grid-template-columns: 1fr 1fr; gap: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .plan {
    padding: 28px 28px 30px;
    display: flex; flex-direction: column; gap: 16px;
  }
  .plan + .plan { border-left: 1px solid var(--line); }
  .plan-head {
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 12px;
    padding-bottom: 16px; border-bottom: 1px solid var(--line);
  }
  .plan-label { font-family: var(--display); font-weight: 700; font-size: 20px; color: var(--fg); }
  .plan-price { font-family: var(--mono); font-size: 13px; color: var(--fg-muted); }
  .plan-head .tag { margin-left: auto; }
  .plan-blurb { margin: 0; color: var(--fg-muted); font-size: 15px; line-height: 1.55; }

  .feat { list-style: none; margin: 4px 0 8px; padding: 0; display: flex; flex-direction: column; flex: 1; }
  .feat li {
    padding: 10px 0;
    color: var(--fg-muted);
    font-size: 14.5px;
    line-height: 1.5;
    border-bottom: 1px solid var(--line);
  }
  .feat li:last-child { border-bottom: 0; }
  .feat li::before { content: '— '; color: var(--fg-faint); font-family: var(--mono); }
  .ent-note { margin: 4px 0 0; font-size: 12.5px; color: var(--fg-faint); text-align: center; line-height: 1.5; }

  @media (max-width: 760px) {
    .oc h2 { font-size: 28px; }
    .plans { grid-template-columns: 1fr; }
    .plan + .plan { border-left: 0; border-top: 1px solid var(--line); }
  }
</style>
