---
import { site } from '../data/site';
---
<section class="hero">
  <div class="container">
    <span class="eyebrow">The Agent Control Plane</span>
    <h1>Where your agents ship at AI speed.</h1>
    <p class="lede hero-lede">
      Frontkeep is the open-source front door agents work through. Point an agent
      at it and it reads your standards, registers its project, provisions real
      infrastructure, and accounts for every dollar — with your policies and
      budgets built in.
    </p>
    <div class="ctas">
      <a class="btn btn-primary" href={site.docs}>Get started →</a>
      <a class="btn btn-ghost" href={site.github}>View on GitHub</a>
    </div>
    <div class="trust">
      <span><b>Apache 2.0</b> · open source</span>
      <span class="sep" aria-hidden="true"></span>
      <span>One static <b>Rust</b> binary</span>
      <span class="sep" aria-hidden="true"></span>
      <code>docker run frontkeep</code>
    </div>

    <div class="code">
      <div class="code-bar">
        <span class="code-title">agent ▸ frontkeep mcp · /mcp</span>
        <span class="code-spacer"></span>
        <span class="code-badge">live session</span>
      </div>
<pre><span class="c"># the agent connects to Frontkeep's MCP control plane</span>
<span class="p">→</span> <span class="k">get_standards</span>            <span class="c">read company standards before writing a line</span>
<span class="o">  ✓ STANDARDS.md, SECURITY.md, WORKFLOW.md (v14)</span>

<span class="p">→</span> <span class="k">register_project</span>  <span class="s">{`{ name: "Fraud Detection", owner, manager, group, class: poc }`}</span>
<span class="o">  ✓ gate passed · minted</span> <span class="t">proj-2026-0042</span>

<span class="p">→</span> <span class="k">gateway_credential</span>  <span class="s">{`{ project: "proj-2026-0042" }`}</span>
<span class="o">  ✓ virtual key issued · budget $100 · models scoped to class</span>

<span class="p">→</span> <span class="k">request_resource</span>   <span class="s">{`{ type: "s3-bucket", name: "training-data" }`}</span>
<span class="o">  ✓ auto-approved · tagged project=proj-2026-0042</span>

<span class="p">→</span> <span class="k">cost_report</span>        <span class="s">{`{ by: "group" }`}</span>
<span class="o">  platform  $41.20   research  $12.80   → every $ attributed</span></pre>
    </div>
  </div>
</section>

<style>
  .hero { padding: 96px 0 80px; }
  .hero h1 {
    font-size: 56px;
    line-height: 1.05;
    font-weight: 700;
    margin: 18px 0 22px;
    max-width: 14ch;
  }
  .hero-lede { font-size: 18px; margin-bottom: 30px; }
  .ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .trust {
    margin-top: 22px;
    font-size: 13.5px;
    color: var(--fg-faint);
    display: flex; align-items: center; gap: 18px; flex-wrap: wrap;
  }
  .trust b { color: var(--fg-muted); font-weight: 600; }
  .trust .sep { width: 3px; height: 3px; border-radius: 50%; background: var(--fg-faint); }
  .trust code {
    background: var(--panel);
    border: 1px solid var(--line);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--fg);
  }
  .code { margin-top: 48px; }

  @media (max-width: 760px) {
    .hero { padding: 56px 0 48px; }
    .hero h1 { font-size: 40px; max-width: 18ch; }
  }
</style>
