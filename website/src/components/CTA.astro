---
import { site } from '../data/site';
---
<section class="section cta">
  <div class="container">
    <div class="cta-card panel">
      <span class="eyebrow">Give your agents a front door</span>
      <h2>Where your agents ship — from first prompt to wide production.</h2>
      <p class="lede">
        Open-source, agent-native, one static binary. Stand it up today; talk to us when you’re
        ready for enterprise identity and high availability.
      </p>
      <div class="ctas">
        <a class="btn btn-primary" href={site.docs}>Read the docs</a>
        <a class="btn btn-ghost" href={site.github}>View on GitHub</a>
        <a class="btn btn-ghost" href={site.contact}>Contact us</a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-card {
    padding: clamp(36px, 5vw, 56px);
    display: flex; flex-direction: column; gap: 18px;
    align-items: flex-start;
  }
  .cta-card h2 {
    font-size: 32px; line-height: 1.2;
    max-width: 22ch;
    margin: 4px 0 4px;
  }
  .ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 6px; }

  @media (max-width: 600px) {
    .cta-card h2 { font-size: 26px; }
  }
</style>
