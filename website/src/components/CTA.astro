---
import { site } from '../data/site';
---
<section class="cta section-pad">
  <div class="container">
    <div class="cta-card" data-reveal>
      <span class="eyebrow">Give your agents a front door</span>
      <h2>Govern AI development<br />from prompt to production.</h2>
      <p class="lede">
        Open source, agents-first, one static binary. Stand it up today; talk to us when you’re
        ready for enterprise identity and high availability.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href={site.docs}>Read the docs</a>
        <a class="btn btn-ghost" href={site.github}>View on GitHub</a>
        <a class="btn btn-ghost" href={site.contact}>Contact us</a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-card {
    position: relative; overflow: hidden;
    border: 1px solid var(--line); border-radius: var(--radius);
    background: var(--panel);
    padding: clamp(40px, 6vw, 76px);
    display: flex; flex-direction: column; align-items: center; text-align: center; gap: 22px;
  }
  .cta-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: var(--bifrost); opacity: 0.8;
  }
  .cta-card h2 { font-size: clamp(30px, 4.6vw, 56px); }
  .cta-card .lede { text-align: center; max-width: 56ch; }
  .cta-row { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-top: 6px; }
</style>
