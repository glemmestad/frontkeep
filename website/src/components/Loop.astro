---
import { loop } from '../data/site';
---
<section class="section loop" id="how">
  <div class="container">
    <span class="eyebrow">The governed onboarding loop</span>
    <h2>One loop, from first prompt to production.</h2>
    <p class="lede">
      The headline workflow, designed agent-first. Every move below is an MCP tool, not a UI
      button. Frontkeep serves the guidance and mints the credentials; the agent does the work.
    </p>

    <ol class="steps panel">
      {loop.map((s) => (
        <li class="step">
          <span class="step-n">{s.n}</span>
          <div class="step-body">
            <div class="step-head">
              <h3>{s.title}</h3>
              {s.key === 'register' && <span class="tag brand"><span class="dot"></span>the gate</span>}
            </div>
            <p>{s.body}</p>
            <code class="chip">{s.tool}</code>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .loop h2 { font-size: 36px; line-height: 1.15; margin: 16px 0 16px; max-width: 24ch; }

  .steps {
    list-style: none; margin: 48px 0 0; padding: 0;
    overflow: hidden;
  }
  .step {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 24px;
    padding: 28px 28px;
    border-bottom: 1px solid var(--line);
  }
  .step:last-child { border-bottom: 0; }
  .step-n {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--brand);
    padding-top: 4px;
  }
  .step-body { display: flex; flex-direction: column; gap: 10px; }
  .step-head { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .step h3 { font-size: 19px; }
  .step p { margin: 0; color: var(--fg-muted); font-size: 15px; line-height: 1.55; }
  .step .chip { align-self: flex-start; margin-top: 4px; }

  @media (max-width: 760px) {
    .loop h2 { font-size: 28px; }
    .step { grid-template-columns: 60px 1fr; gap: 16px; padding: 20px 20px; }
  }
</style>
