---
const points = [
  ['Any cloud, any service', 'The terraform connector is the universal path. AWS, Databricks, Auth0 — same manifest, same cost plumbing.'],
  ['Any model backend',      'OpenAI & Anthropic built in. LiteLLM, Databricks Model Serving, vLLM — each an enableable plugin, never core code.'],
  ['Cost reads itself',      'The manifest also declares how the service’s cost is attributed, so spend flows into the same rollup automatically.'],
];
---
<section class="section extend" id="extend">
  <div class="container">
    <div class="grid">
      <div class="copy">
        <span class="eyebrow">Extensible by manifest</span>
        <h2>A new service is a file, not a code change.</h2>
        <p class="lede">
          Everything an agent can provision is one YAML plus a Terraform module. The manifest
          declares how it’s provisioned <em>and</em> how its cost is attributed, so the catalog
          grows without touching the binary.
        </p>
        <dl class="points">
          {points.map(([t, d]) => (
            <div class="point">
              <dt>{t}.</dt>
              <dd>{d}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="code">
        <div class="code-bar">
          <span class="code-title">services/s3-bucket/service.yaml</span>
        </div>
<pre><span class="k">id</span>: s3-bucket
<span class="k">category</span>: storage
<span class="k">classification_min</span>: poc
<span class="k">auto_approvable</span>: <span class="o">true</span>
<span class="k">required_fields</span>: [name]
<span class="k">provisioner</span>:
  <span class="k">connector</span>: <span class="s">terraform</span>
  <span class="k">config</span>: {`{ `}<span class="k">module</span>: <span class="s">aws/s3-bucket</span>{` }`}
<span class="k">cost</span>:
  <span class="k">source</span>: {`{ `}<span class="k">type</span>: <span class="s">aws-cost-explorer</span>{` }`}
<span class="k">secret_outputs</span>: [bucket_arn]</pre>
      </div>
    </div>
  </div>
</section>

<style>
  .extend .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: start; }
  .extend h2 { font-size: 32px; line-height: 1.15; margin: 16px 0 16px; max-width: 22ch; }
  .extend em { font-style: normal; color: var(--brand); font-weight: 600; }
  .points { margin: 24px 0 0; padding: 0; }
  .point { padding: 14px 0; border-bottom: 1px solid var(--line); }
  .point:last-child { border-bottom: 0; }
  .point dt { font-weight: 600; color: var(--fg); display: inline; margin-right: 6px; }
  .point dd { display: inline; margin: 0; color: var(--fg-muted); font-size: 15px; line-height: 1.55; }

  @media (max-width: 900px) {
    .extend .grid { grid-template-columns: 1fr; gap: 36px; }
    .extend h2 { font-size: 26px; }
  }
</style>
