---
import { faqs } from '../data/site';
---
<section class="section faq" id="faq">
  <div class="container faq-inner">
    <div class="faq-head">
      <span class="eyebrow">Questions</span>
      <h2>The short answers.</h2>
    </div>
    <div class="faq-list panel">
      {faqs.map((f, i) => (
        <details class="qa" open={i === 0}>
          <summary>
            <span>{f.q}</span>
            <span class="chev" aria-hidden="true"></span>
          </summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-inner { display: grid; grid-template-columns: 0.7fr 1.3fr; gap: 56px; align-items: start; }
  .faq-head h2 { font-size: 32px; line-height: 1.15; margin: 16px 0 0; }
  .faq-list { display: flex; flex-direction: column; overflow: hidden; }

  .qa { border-bottom: 1px solid var(--line); }
  .qa:last-child { border-bottom: 0; }
  .qa summary {
    list-style: none; cursor: pointer;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    padding: 20px 22px;
    font-weight: 600; font-size: 16px;
    color: var(--fg);
  }
  .qa summary:hover { background: var(--panel); }
  .qa summary::-webkit-details-marker { display: none; }
  .qa .chev {
    flex: none; width: 12px; height: 12px; position: relative;
    transition: transform 0.15s;
  }
  .qa .chev::before, .qa .chev::after {
    content: ''; position: absolute; top: 50%; left: 50%;
    width: 11px; height: 1.5px; border-radius: 1px;
    background: var(--fg-muted);
    transform: translate(-50%, -50%);
  }
  .qa .chev::after { transform: translate(-50%, -50%) rotate(90deg); transition: opacity 0.15s; }
  .qa[open] .chev::after { opacity: 0; }
  .qa p {
    margin: 0;
    padding: 0 22px 22px;
    color: var(--fg-muted);
    font-size: 14.5px;
    line-height: 1.6;
  }

  @media (max-width: 760px) {
    .faq-inner { grid-template-columns: 1fr; gap: 20px; }
    .faq-head h2 { font-size: 26px; }
  }
</style>
