---
const surfaces = [
  ['CLI',  'frontkeep',                'A typed subcommand for every MCP tool — same authority, scriptable.'],
  ['MCP',  '/mcp',                     'Remote MCP server. Connect Claude Code, Cursor, Codex with a PAT.'],
  ['UI',   '/',                        'Embedded web UI. Dashboards, projects, catalog, cost, audit.'],
  ['REST', '/api/*',                   'Stable REST surface for everything an MCP tool can do.'],
  ['GraphQL', '/graphql',              'GraphQL endpoint for richer reads.'],
];
---
<section class="section surfaces" id="surfaces">
  <div class="container">
    <span class="eyebrow">Five front doors. One control plane.</span>
    <h2>Whichever surface a caller prefers, the same governance applies.</h2>
    <p class="lede">
      Every capability is reachable from every surface — and routed through the same policy,
      audit and cost layer. There’s no “API tier” and “UI tier” drifting apart.
    </p>

    <table class="surface-table">
      <thead>
        <tr><th>Surface</th><th>Path</th><th>Used by</th></tr>
      </thead>
      <tbody>
        {surfaces.map(([name, path, used]) => (
          <tr>
            <td class="name">{name}</td>
            <td class="path"><code>{path}</code></td>
            <td class="used">{used}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<style>
  .surfaces h2 { font-size: 32px; line-height: 1.15; margin: 16px 0 16px; max-width: 28ch; }

  .surface-table {
    margin-top: 40px;
    width: 100%;
    border-collapse: collapse;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    font-size: 14.5px;
  }
  .surface-table th, .surface-table td {
    text-align: left;
    padding: 14px 20px;
    border-bottom: 1px solid var(--line);
  }
  .surface-table thead th {
    font-family: var(--mono);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--fg-faint);
    background: var(--panel);
  }
  .surface-table tbody tr:last-child td { border-bottom: 0; }
  .surface-table .name { font-weight: 600; color: var(--fg); width: 12%; }
  .surface-table .path { width: 22%; }
  .surface-table .path code {
    font-family: var(--mono); font-size: 13px; color: var(--brand);
  }
  .surface-table .used { color: var(--fg-muted); }

  @media (max-width: 720px) {
    .surfaces h2 { font-size: 26px; }
    .surface-table { font-size: 13.5px; }
    .surface-table th, .surface-table td { padding: 10px 14px; }
    .surface-table .name { width: auto; white-space: nowrap; }
    .surface-table .path { width: auto; }
  }
</style>
