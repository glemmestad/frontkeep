---
import { mcpTools } from '../data/site';
---
<section class="section agents" id="agents">
  <div class="container">
    <div class="grid">
      <div class="copy">
        <span class="eyebrow">Agents first, humans second</span>
        <h2>Every capability is an MCP tool, not just a button.</h2>
        <p class="lede">
          Most platforms bolt an API onto a human UI. Frontkeep is built the other way around:
          the control plane <em>is</em> the agent interface. Discover services, register projects,
          fetch credentials, read standards, request resources — all as tools an agent can call,
          with the same authority a human gets in the dashboard.
        </p>
        <div class="tools">
          {mcpTools.map((t) => <code class="chip">{t}</code>)}
          <span class="more">+ more</span>
        </div>
      </div>

      <div class="code">
        <div class="code-bar">
          <span class="code-title">~/.claude/mcp.json</span>
        </div>
<pre>{`{
  `}<span class="k">"mcpServers"</span>{`: {
    `}<span class="k">"frontkeep"</span>{`: {
      `}<span class="k">"type"</span>{`: `}<span class="s">"http"</span>{`,
      `}<span class="k">"url"</span>{`: `}<span class="s">"https://frontkeep.your-co.com/mcp"</span>{`,
      `}<span class="k">"headers"</span>{`: {
        `}<span class="k">"Authorization"</span>{`: `}<span class="s">"Bearer asg_pat_…"</span>{`
      }
    }
  }
}`}</pre>
      </div>
    </div>
  </div>
</section>

<style>
  .agents .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: start; }
  .agents h2 { font-size: 32px; line-height: 1.15; margin: 16px 0 16px; max-width: 22ch; }
  .agents em { font-style: normal; color: var(--brand); font-weight: 600; }
  .tools { margin-top: 24px; display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
  .tools .more { font-size: 12.5px; color: var(--fg-faint); margin-left: 4px; }

  @media (max-width: 900px) {
    .agents .grid { grid-template-columns: 1fr; gap: 36px; }
    .agents h2 { font-size: 26px; }
  }
</style>
