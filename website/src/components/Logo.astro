---
interface Props { size?: number; withWordmark?: boolean; }
const { size = 22, withWordmark = true } = Astro.props;
---
<a href="/" class="logo" aria-label="Frontkeep home">
  <span class="glyph" style={`width:${size}px; height:${size}px; font-size:${Math.round(size * 0.6)}px;`}>F</span>
  {withWordmark && <span class="wordmark">Frontkeep</span>}
</a>

<style>
  .logo { display: inline-flex; align-items: center; gap: 10px; }
  .logo:hover { text-decoration: none; }
  .glyph {
    display: inline-grid;
    place-items: center;
    background: var(--brand);
    color: #fff;
    font-weight: 700;
    border-radius: 4px;
    line-height: 1;
  }
  .wordmark {
    font-family: var(--display);
    font-weight: 700;
    font-size: 16px;
    color: var(--fg);
    letter-spacing: -0.005em;
  }
</style>
